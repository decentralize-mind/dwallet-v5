# ── dWallet v5 Environment Variables ─────────────────────────────────
# Copy to .env.local and fill in. Never commit .env.local to Git.

# ── RPC (required for live balances + DeFi) ───────────────────────────
# Free at https://infura.io → New Project → Ethereum → copy Project ID
VITE_INFURA_KEY=

# ── NFT Gallery (required for real NFTs) ─────────────────────────────
# Free at https://alchemy.com → Create App → Ethereum Mainnet → API Key
VITE_ALCHEMY_ETH=

# ── Transaction History (optional, increases history limit) ───────────
# Free at https://etherscan.io/apis (2 calls/sec without key still works)
VITE_ETHERSCAN_KEY=

# ── WalletConnect (required for dApp connections) ─────────────────────
# Free at https://cloud.walletconnect.com → New Project → copy ID
VITE_WALLETCONNECT_PROJECT_ID=

# ── Vercel: Add all above in Project → Settings → Environment Variables
# Without keys: wallet runs in preview mode with mock data
# With keys: fully live on-chain
