{
  "manifest_version": 3,
  "name": "Toklo \u2014 DeFi Wallet",
  "version": "2.0.0",
  "description": "Non-custodial DeFi wallet with AI agent and DWT token ecosystem",
  "action": {
    "default_popup": "index.html",
    "default_title": "dWallet",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://mainnet.infura.io/*",
    "https://bsc-dataseed.binance.org/*",
    "https://polygon-rpc.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "icons": [
    {
      "src": "/favicon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    }
  ],
  "short_name": "Toklo",
  "start_url": "/",
  "scope": "/",
  "id": "/",
  "theme_color": "#6366f1",
  "background_color": "#f0f2f5"
}
